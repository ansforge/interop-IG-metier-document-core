     fhir:Narrative.status [ fhir:value "generated" ] ;
     fhir:Narrative.div "<div xml:lang=\"fr\" lang=\"fr\"><hr/><p><b>French</b></p><hr/><p class=\"res-header-id\"><b>Narratif généré : CarteDeConcepts FRDeviceUseStatementLMCDAFHIR</b></p><a name=\"FRDeviceUseStatementLMCDAFHIR\"> </a><a name=\"hcFRDeviceUseStatementLMCDAFHIR\"> </a><p>This mapping does not specify any particular context of use.</p><br/><p><b>Groupe 1 </b>Mapping de <code>https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-lm-dispositif-medical-entree</code> to <code>https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-dispositif-medical</code></p><table class=\"grid\"><tr><td><b>Code source</b></td><td><b>relation</b></td><td><b>Code cible</b></td></tr><tr><td>FRLMDispositifMedicalEntree</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>FRCDADispositifMedical</td></tr><tr><td>FRLMDispositifMedicalEntree.identifiant</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>FRCDADispositifMedical.id</td></tr><tr><td>FRLMDispositifMedicalEntree.date</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>FRCDADispositifMedical.effectiveTime</td></tr><tr><td>FRLMDispositifMedicalEntree.dispensateur</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>FRCDADispositifMedical.performer</td></tr><tr><td>FRLMDispositifMedicalEntree.dispositifMedical</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>FRCDADispositifMedical.participant</td></tr><tr><td>FRLMDispositifMedicalEntree.affectionLongueDuree</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>FRCDADispositifMedical.entryRelationship:frEnRapportAvecALD</td></tr><tr><td>FRLMDispositifMedicalEntree.accidentTravail</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>FRCDADispositifMedical.entryRelationship:frEnRapportAvecAccidentTravail</td></tr><tr><td>FRLMDispositifMedicalEntree.prevention</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>FRCDADispositifMedical.entryRelationship:frEnRapportAvecPrevention</td></tr></table><hr/><p><b>Groupe 2 </b>Mapping de <code>https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-dispositif-medical</code> to <code>https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-device-use-statement-document</code></p><table class=\"grid\"><tr><td><b>Code source</b></td><td><b>relation</b></td><td><b>Code cible</b></td></tr><tr><td>FRCDADispositifMedical</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>FRDeviceUseStatementDocument</td></tr><tr><td>FRCDADispositifMedical.id</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>FRDeviceUseStatementDocument.identifier</td></tr><tr><td>FRCDADispositifMedical.effectiveTime</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>FRDeviceUseStatementDocument.timing[x]</td></tr><tr><td>FRCDADispositifMedical.performer</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>FRDeviceUseStatementDocument.source.extension:performer</td></tr><tr><td>FRCDADispositifMedical.participant</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>FRDeviceUseStatementDocument.device</td></tr><tr><td>FRCDADispositifMedical.entryRelationship:frEnRapportAvecALD</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>FRDeviceUseStatementDocument.reasonReference:EnRapportAvecALD</td></tr><tr><td>FRCDADispositifMedical.entryRelationship:frEnRapportAvecAccidentTravail</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>FRDeviceUseStatementDocument.reasonReference:EnRapportAvecAccidentTravail</td></tr><tr><td>FRCDADispositifMedical.entryRelationship:frEnRapportAvecPrevention</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>FRDeviceUseStatementDocument.reasonReference:EnRapportAvecLaPrevention</td></tr><tr><td>FRCDADispositifMedical.entryRelationship:frNonRemboursable</td><td><a href=\"http://hl7.org/fhir/R5/codesystem-concept-map-relationship.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>FRDeviceUseStatementDocument.extension:notCovered</td></tr></table></div>"
